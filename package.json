{
  "name": "easybill-lab",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@sap/cds": "^9",
    "@sap/cds-dk": "^9.8.0",
    "dotenv": "^17.3.1",
    "express": "^4",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.2",
    "pdfkit": "^0.17.2"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^0.4.1",
    "@cap-js/sqlite": "^2.2.0",
    "@jest/globals": "^30.3.0",
    "jest": "^30.3.0"
  },
  "scripts": {
    "start": "cds-serve",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "testMatch": [
      "**/test/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "srv/**/*.js",
      "!srv/**/index.js"
    ],
    "coverageReporters": [
      "text",
      "html"
    ]
  },
  "private": true
}
